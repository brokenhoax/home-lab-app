# Copy this file to backend.env and set values for your environment.
#   cp backend.env.example backend.env
#
# Used by docker compose for the backend and ingest services (see docker-compose.yml).
# Do not commit backend.env — it is gitignored.
#
# Compose still sets stack defaults (internal CHROMA_URL, host Ollama URL, NODE_ENV).
# Variables you set here override those defaults when non-empty.

# --- API keys (optional) ---
# Zscaler AI Guard — leave empty to skip guard calls
AI_GUARD_KEY=

# xAI — required only if you use the xAI chat provider in the backend
XAI_API_KEY=

# --- Bind addresses (development / custom deploys) ---
# DEV_ENV_IP_ADDR: backend listen address in development (see blog-backend server.ts)
DEV_ENV_IP_ADDR=
PROD_ENV_IP_ADDR=

# --- TLS (production HTTPS on the host, not typical for home-lab compose) ---
CERT_KEY_PATH=
CERT_CERT_PATH=

# --- Optional overrides (defaults work for standard home-lab bootstrap) ---
# Internal Chroma from backend container (default in compose: http://chroma:8000)
# CHROMA_URL=http://chroma:8000

# Ollama API from backend container (default: http://host.docker.internal:11434)
# OLLAMA_HOST=http://host.docker.internal:11434
